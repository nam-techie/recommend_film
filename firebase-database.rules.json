{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "publicProfiles": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['uid','username','displayName','createdAt','updatedAt','isPublic']) && newData.child('uid').val() === $uid && newData.child('username').isString() && newData.child('username').val().matches(/^[a-z0-9_]{3,24}$/) && newData.child('displayName').isString() && newData.child('displayName').val().length <= 40 && (!newData.child('bio').exists() || newData.child('bio').val().length <= 180)"
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || (data.val() === auth.uid && (!newData.exists() || newData.val() === auth.uid)))",
        ".validate": "!newData.exists() || ($username.matches(/^[a-z0-9_]{3,24}$/) && newData.val() === auth.uid)"
      }
    },
    "watchlists": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "publicWatchlists": {
      ".read": true,
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    },
    "publicRecent": {
      ".read": true,
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    },
    "following": {
      ".read": true,
      "$uid": {
        "$targetUid": { ".write": "auth != null && (auth.uid === $uid || (!newData.exists() && auth.uid === $targetUid))", ".validate": "!newData.exists() || newData.val() === true" }
      }
    },
    "followers": {
      ".read": true,
      "$targetUid": {
        "$followerUid": { ".write": "auth != null && (auth.uid === $followerUid || (!newData.exists() && auth.uid === $targetUid))", ".validate": "!newData.exists() || newData.val() === true" }
      }
    },
    "friendRequests": {
      "$recipientUid": {
        ".read": "auth != null && auth.uid === $recipientUid",
        "$senderUid": {
          ".write": "auth != null && ((auth.uid === $senderUid && (!data.exists() || !newData.exists())) || auth.uid === $recipientUid)",
          ".validate": "!newData.exists() || (newData.child('uid').val() === $senderUid && newData.child('username').isString() && newData.child('displayName').isString() && newData.child('createdAt').isNumber())"
        }
      }
    },
    "sentFriendRequests": {
      "$senderUid": {
        ".read": "auth != null && auth.uid === $senderUid",
        "$recipientUid": {
          ".write": "auth != null && (auth.uid === $senderUid || (!newData.exists() && auth.uid === $recipientUid))",
          ".validate": "!newData.exists() || (newData.child('uid').val() === $recipientUid && newData.child('username').isString() && newData.child('displayName').isString() && newData.child('createdAt').isNumber())"
        }
      }
    },
    "friendships": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid) && (!newData.exists() || root.child('friendRequests').child($uid).child($friendUid).exists() || root.child('friendRequests').child($friendUid).child($uid).exists())",
          ".validate": "!newData.exists() || (newData.child('uid').val() === $friendUid && newData.child('username').isString() && newData.child('displayName').isString() && newData.child('createdAt').isNumber())"
        }
      }
    },
    "blocks": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$blockedUid": { ".write": "auth != null && auth.uid === $uid", ".validate": "!newData.exists() || newData.val() === true" }
      }
    },
    "presenceConnections": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('friendships').child($uid).child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid",
        "$connectionId": { ".validate": "!newData.exists() || newData.val() === true" }
      }
    },
    "presenceLastSeen": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('friendships').child($uid).child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "!newData.exists() || newData.isNumber()"
      }
    },
    "directConversations": {
      "$conversationId": {
        ".read": "auth != null && ((data.child('memberA').val() === auth.uid && root.child('friendships').child(auth.uid).child(data.child('memberB').val()).exists() && !root.child('blocks').child(auth.uid).child(data.child('memberB').val()).exists() && !root.child('blocks').child(data.child('memberB').val()).child(auth.uid).exists()) || (data.child('memberB').val() === auth.uid && root.child('friendships').child(auth.uid).child(data.child('memberA').val()).exists() && !root.child('blocks').child(auth.uid).child(data.child('memberA').val()).exists() && !root.child('blocks').child(data.child('memberA').val()).child(auth.uid).exists()))",
        ".write": "auth != null && ((newData.child('memberA').val() === auth.uid && root.child('friendships').child(auth.uid).child(newData.child('memberB').val()).exists() && !root.child('blocks').child(auth.uid).child(newData.child('memberB').val()).exists() && !root.child('blocks').child(newData.child('memberB').val()).child(auth.uid).exists()) || (newData.child('memberB').val() === auth.uid && root.child('friendships').child(auth.uid).child(newData.child('memberA').val()).exists() && !root.child('blocks').child(auth.uid).child(newData.child('memberA').val()).exists() && !root.child('blocks').child(newData.child('memberA').val()).child(auth.uid).exists()))",
        ".validate": "newData.hasChildren(['id','memberA','memberB','memberUids','lastMessage','lastMessageType','lastSenderUid','lastMessageAt','createdAt','updatedAt']) && newData.child('id').val() === $conversationId && newData.child('memberA').isString() && newData.child('memberB').isString() && newData.child('memberA').val() !== newData.child('memberB').val() && (!data.exists() || (newData.child('memberA').val() === data.child('memberA').val() && newData.child('memberB').val() === data.child('memberB').val() && newData.child('createdAt').val() === data.child('createdAt').val())) && newData.child('memberUids').child(newData.child('memberA').val()).val() === true && newData.child('memberUids').child(newData.child('memberB').val()).val() === true && newData.child('lastMessage').isString() && newData.child('lastMessage').val().length <= 1000 && (newData.child('lastMessageType').val() === 'text' || newData.child('lastMessageType').val() === 'watch_party_invite' || newData.child('lastMessageType').val() === 'system') && newData.child('lastMessageAt').isNumber() && newData.child('createdAt').isNumber() && newData.child('updatedAt').isNumber()"
      }
    },
    "directMessages": {
      "$conversationId": {
        ".read": "auth != null && ((root.child('directConversations').child($conversationId).child('memberA').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberB').val()).exists() && !root.child('blocks').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberB').val()).exists()) || (root.child('directConversations').child($conversationId).child('memberB').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberA').val()).exists() && !root.child('blocks').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberA').val()).exists()))",
        "$messageId": {
          ".write": "auth != null && !data.exists() && newData.child('senderUid').val() === auth.uid && ((root.child('directConversations').child($conversationId).child('memberA').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberB').val()).exists() && !root.child('blocks').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberB').val()).exists() && !root.child('blocks').child(root.child('directConversations').child($conversationId).child('memberB').val()).child(auth.uid).exists()) || (root.child('directConversations').child($conversationId).child('memberB').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberA').val()).exists() && !root.child('blocks').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberA').val()).exists() && !root.child('blocks').child(root.child('directConversations').child($conversationId).child('memberA').val()).child(auth.uid).exists()))",
          ".validate": "newData.hasChildren(['id','conversationId','senderUid','senderName','type','text','createdAt']) && newData.child('id').val() === $messageId && newData.child('conversationId').val() === $conversationId && newData.child('type').val() === 'text' && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 1000 && newData.child('createdAt').isNumber()"
        }
      }
    },
    "userConversations": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$conversationId": {
          ".validate": "!newData.exists() || (newData.child('conversationId').val() === $conversationId && newData.child('otherUid').isString() && newData.child('lastReadAt').isNumber() && newData.child('muted').isBoolean() && newData.child('updatedAt').isNumber()) || (!newData.child('conversationId').exists() && !newData.child('otherUid').exists() && !newData.child('lastReadAt').exists() && !newData.child('muted').exists() && newData.child('updatedAt').isNumber())",
          "conversationId": { ".validate": "newData.isString() && newData.val() === $conversationId" },
          "otherUid": { ".validate": "newData.isString()" },
          "lastReadAt": { ".validate": "newData.isNumber()" },
          "muted": { ".validate": "newData.isBoolean()" },
          "updatedAt": { ".write": "auth != null && (auth.uid === $uid || root.child('friendships').child($uid).child(auth.uid).exists())", ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      }
    },
    "directTyping": {
      "$conversationId": {
        ".read": "auth != null && ((root.child('directConversations').child($conversationId).child('memberA').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberB').val()).exists()) || (root.child('directConversations').child($conversationId).child('memberB').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberA').val()).exists()))",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && ((root.child('directConversations').child($conversationId).child('memberA').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberB').val()).exists()) || (root.child('directConversations').child($conversationId).child('memberB').val() === auth.uid && root.child('friendships').child(auth.uid).child(root.child('directConversations').child($conversationId).child('memberA').val()).exists()))",
          ".validate": "!newData.exists() || (newData.child('typing').val() === true && newData.child('updatedAt').isNumber())"
        }
      }
    },
    "watchPartyInvites": {
      ".indexOn": ["recipientUid", "roomId", "expiresAt"],
      "$inviteId": {
        ".read": "auth != null && (data.child('inviterUid').val() === auth.uid || data.child('recipientUid').val() === auth.uid)",
        ".write": false
      }
    },
    "reviews": {
      ".read": true,
      "$movieSlug": {
        "$authorUid": {
          ".write": "auth != null && auth.uid === $authorUid",
          ".validate": "newData.hasChildren(['id','movieSlug','movieTitle','authorUid','authorName','authorUsername','rating','content','createdAt','updatedAt']) && newData.child('authorUid').val() === $authorUid && newData.child('movieSlug').val() === $movieSlug && newData.child('rating').isNumber() && newData.child('rating').val() >= 1 && newData.child('rating').val() <= 10 && newData.child('content').isString() && newData.child('content').val().length >= 10 && newData.child('content').val().length <= 1200"
        }
      }
    },
    "reviewLikes": {
      ".read": true,
      "$movieSlug": {
        "$authorUid": {
          ".write": "auth != null && auth.uid === $authorUid",
          "$likerUid": { ".write": "auth != null && auth.uid === $likerUid", ".validate": "!newData.exists() || newData.val() === true" }
        }
      }
    },
    "reviewReplies": {
      ".read": true,
      "$movieSlug": {
        "$reviewAuthorUid": {
          ".write": "auth != null && auth.uid === $reviewAuthorUid",
          "$replyId": { ".write": "auth != null && ((!data.exists() && newData.child('authorUid').val() === auth.uid) || data.child('authorUid').val() === auth.uid)", ".validate": "!newData.exists() || (newData.child('content').isString() && newData.child('content').val().length > 0 && newData.child('content').val().length <= 300)" }
        }
      }
    },
    "activities": {
      ".read": true,
      "$uid": {
        "$activityId": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.child('actorUid').val() === $uid" }
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notificationId": {
          ".write": "auth != null && (auth.uid === $uid || (!data.exists() && newData.child('actorUid').val() === auth.uid))",
          ".validate": "!newData.exists() || (newData.child('actorUid').isString() && newData.child('type').isString() && newData.child('createdAt').isNumber())"
        }
      }
    },
    "reports": {
      "$reportId": {
        ".read": false,
        ".write": "auth != null && !data.exists() && newData.child('reporterUid').val() === auth.uid"
      }
    },
    ".read": false,
    ".write": false
  }
}
