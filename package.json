{
  "name": "cinemind",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,watch-party --prefix-colors cyan,magenta \"next dev\" \"node --watch socket-server/server.js\"",
    "dev:web": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "socket:dev": "npm --prefix socket-server run dev",
    "socket:start": "npm --prefix socket-server start"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.1.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.50.3",
    "@tailwindcss/line-clamp": "^0.4.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^11.10.0",
    "hls.js": "^1.5.18",
    "livekit-client": "^2.15.6",
    "lucide-react": "^0.454.0",
    "next": "14.2.25",
    "next-themes": "^0.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "postcss": "^8",
    "rxjs": "^7.8.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
